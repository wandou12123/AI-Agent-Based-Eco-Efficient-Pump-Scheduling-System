# ===== 大模型 API（通义千问 / DashScope OpenAI 兼容模式）=====
LLM_API_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_API_KEY=sk-your-dashscope-api-key
# 可选模型：qwen-turbo / qwen-plus / qwen-max / qwen-long
LLM_MODEL_NAME=qwen-turbo

# ===== MySQL 数据库 =====
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_password
MYSQL_DATABASE=pump_station

# ===== JWT =====
JWT_SECRET_KEY=change-this-to-a-random-secret-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ===== Redis / Celery（可选，Docker 部署时启用）=====
REDIS_URL=redis://127.0.0.1:6379/0
CELERY_BROKER_URL=redis://127.0.0.1:6379/1
USE_CELERY=false
